# Exclude Hermes-specific files from OpenClaw/npm installation
adapters/
plugin.yaml
__init__.py
HERMES_ADAPTATION_ANALYSIS_V2.md
start-web-hermes.sh

# Exclude development and temp files
.git
.gemini
node_modules
tsconfig.json
vitest.config.ts
src/__tests__
web/api-hermes/
web/frontend/
web/shared/
!web/api/dist

# Kernel probes spawn child processes (node:child_process), which the OpenClaw
# plugin scanner blocks. They are NOT bundled in the OpenClaw plugin — run them
# standalone (see README "Standalone eBPF launch"). The authoritative exclusion
# is the package.json "files" allowlist; these entries are a defensive belt.
sentinel/probes/ebpf/
sentinel/probes/uprobe/
sentinel/probes/lsm/
