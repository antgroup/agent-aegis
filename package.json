{
  "name": "@antgroup/agent-aegis",
  "version": "2026.3.14",
  "private": false,
  "description": "OpenClaw runtime safety guard plugin (AgentAegis) — multi-layer defense for prompt, tool, and tool-result flows.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/antgroup/agent-aegis.git"
  },
  "homepage": "https://github.com/antgroup/agent-aegis#readme",
  "bugs": {
    "url": "https://github.com/antgroup/agent-aegis/issues"
  },
  "main": "index.js",
  "files": [
    "index.js",
    "index.d.ts",
    "runtime-api.js",
    "runtime-api.d.ts",
    "src/**/*.js",
    "src/**/*.d.ts",
    "openclaw.plugin.json",
    "README.md",
    "README_zh.md",
    "LEGAL.md",
    "LICENSE",
    "rpc-handlers.ts",
    "rpc-handlers.js",
    "rpc-server.ts",
    "rpc-server.js",
    "sentinel/index.ts",
    "sentinel/index.js",
    "sentinel/bootstrap.ts",
    "sentinel/bootstrap.js",
    "sentinel/README.md",
    "sentinel/channel/",
    "sentinel/judges/",
    "sentinel/runtime/",
    "sentinel/probes/types.ts",
    "sentinel/probes/types.js"
  ],
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:ebpf": "bash sentinel/probes/ebpf/verify-e2e.sh",
    "e2e:uprobe": "bash sentinel/probes/uprobe/verify-e2e.sh",
    "e2e:lsm": "bash sentinel/probes/lsm/verify-e2e.sh",
    "observe:live": "bash sentinel/probes/ebpf/observe-live.sh",
    "observe:hermes": "bash sentinel/probes/ebpf/observe-hermes.sh"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
