{
  "name": "@openclaw/agent-aegis",
  "version": "2026.3.14",
  "private": true,
  "description": "OpenClaw safety guard plugin for prompt, tool, and tool-result hardening.",
  "type": "module",
  "main": "index.js",
  "files": [
    "index.ts",
    "index.js",
    "src/",
    "runtime-api.ts",
    "runtime-api.js",
    "openclaw.plugin.json",
    "package.json",
    "README.md",
    "README_zh.md",
    "LICENSE",
    "rpc-handlers.ts",
    "rpc-handlers.js",
    "rpc-server.ts",
    "rpc-server.js",
    "sentinel/"
  ],
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:ebpf": "bash sentinel/probes/ebpf/verify-e2e.sh",
    "e2e:uprobe": "bash sentinel/probes/uprobe/verify-e2e.sh",
    "e2e:lsm": "bash sentinel/probes/lsm/verify-e2e.sh",
    "observe:live": "bash sentinel/probes/ebpf/observe-live.sh"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
