  "defenseGroups": {
    "selfProtection": {
      "label": "保护敏感路径",
      "help": "拦截针对受保护路径、重要技能的读写删除和搜索操作，或阻止删除当前工作区外的文件。"
    },
    "commandBlock": {
      "label": "拦截高风险命令",
      "help": "拦截明确的高风险 Shell 模式，如 rm -rf / 和 curl | sh。"
    },
    "encodingGuard": {
      "label": "防护编码载荷",
      "help": "检测隐藏风险命令或外泄逻辑的 base64/base32/hex/url 编码载荷。"
    },
    "scriptProvenanceGuard": {
      "label": "追踪脚本来源",
      "help": "追踪当前运行中新写入的脚本，并在后续执行中拦截携带风险命令或外泄信号的脚本。"
    },
    "memoryGuard": {
      "label": "防护内存写入",
      "help": "拒绝对 memory_store、MEMORY.md、SOUL.md 和 memory/ 的可疑或超大写入。"
    },
    "loopGuard": {
      "label": "启用循环守卫",
      "help": "在每次运行的重试预算用尽后，停止重复的变更工具调用。"
    },
    "exfiltrationGuard": {
      "label": "防护外泄链",
      "help": "追踪每次运行中的先前工具调用，拦截类似 SSRF 或密钥外泄的可疑出站链。"
    },
    "userRiskScan": {
      "label": "扫描用户意图",
      "help": "在 message_received 中检测越狱、密钥外泄和插件篡改请求。"
    },
    "skillScan": {
      "label": "扫描技能",
      "help": "为 ~/.openclaw/skills 和 ~/.openclaw/workspace/skills 启用轻量级本地技能扫描器。"
    },
    "toolResultScan": {
      "label": "扫描工具结果",
      "help": "扫描 toolResult 内容中的提示注入、密钥请求和外泄模式。"
    },
    "outputRedaction": {
      "label": "脱敏输出内容",
      "help": "在助手输出发送或持久化前，遮蔽 API 密钥、令牌等敏感值。"
    },
    "promptGuard": {
      "label": "注入提示守卫",
      "help": "在 before_prompt_build 期间注入静态和一次性安全提醒。"
    },
    "dispatchGuard": {
      "label": "指令拦截守卫",
      "help": "在用户消息到达 AI 前和 LLM 回复前拦截危险操作请求，包括 openclaw CLI 命令、保护路径破坏、绕过 tool call 等。"
    },
    "toolCallEnforcement": {
      "label": "强制 Tool Call 执行",
      "help": "通过 prompt 注入要求所有破坏性操作必须通过标准 tool call 执行，禁止绕过安全 hook。"
    }
  }
