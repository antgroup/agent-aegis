{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": ".",
    "declaration": false
  },
  "include": ["*.ts", "src/**/*.ts", "sentinel/**/*.ts"],
  "exclude": ["web", "node_modules", "adapters", "sentinel/**/__tests__/**"]
}
