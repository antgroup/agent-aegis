{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": true,
    "declaration": true,
    "outDir": ".",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["*.ts", "src/**/*.ts"],
  "exclude": ["web", "node_modules", "adapters", "**/__tests__/**", "**/*.test.ts"]
}
