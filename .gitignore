# ─────────────────────────────────────────────────────────────────────────
# Keep only the minimal, runnable plugin in git.
# Test/verification harnesses, build outputs, logs, and local/personal agent
# config stay LOCAL ONLY (never published).
# ─────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build artifacts (regenerated by `npm run build` / `tsc`)
web/api/dist/
web/shared/dist/
web/frontend/dist/
*.tsbuildinfo
__pycache__/
*.pyc

# Lockfiles (regenerated on install)
package-lock.json

# Tests & local verification harness — must NOT be uploaded
src/__tests__/
**/__tests__/
*.test.ts
*.spec.ts
vitest.config.ts
test_*.py
test_*.mjs
docker/
.dockerignore
*.log

# Local / personal agent & tooling config — desensitized: never commit
CLAUDE.md
.claude/
.mcp.json
.gemini/
.cursor/
.vscode/

# OS junk
.DS_Store
Thumbs.db

CHANGELOG*.md
